{
  "name": "code-snippet-manager",
  "displayName": "Code Snippet Manager Pro",
  "description": "🚀 Advanced code snippet management with real-time sync, AI-powered organization, and team collaboration features",
  "version": "1.0.0",
  "publisher": "snippet-manager-pro",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Snippets",
    "Other",
    "Extension Packs"
  ],
  "keywords": [
    "snippets",
    "code-management",
    "productivity",
    "sync",
    "collaboration",
    "ai-powered",
    "developer-tools"
  ],
  "activationEvents": [
    "onCommand:snippetManager.insertSnippet",
    "onCommand:snippetManager.saveSelection",
    "onCommand:snippetManager.searchSnippets",
    "onCommand:snippetManager.syncSnippets",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "snippetManager.insertSnippet",
        "title": "📋 Insert Snippet",
        "category": "Snippet Manager"
      },
      {
        "command": "snippetManager.saveSelection",
        "title": "💾 Save Selected Code as Snippet",
        "category": "Snippet Manager"
      },
      {
        "command": "snippetManager.searchSnippets",
        "title": "🔍 Search Snippets",
        "category": "Snippet Manager"
      },
      {
        "command": "snippetManager.openDashboard",
        "title": "🌐 Open Web Dashboard",
        "category": "Snippet Manager"
      },
      {
        "command": "snippetManager.syncSnippets",
        "title": "🔄 Sync Snippets",
        "category": "Snippet Manager"
      },
      {
        "command": "snippetManager.createCollection",
        "title": "📁 Create Collection",
        "category": "Snippet Manager"
      },
      {
        "command": "snippetManager.bulkImport",
        "title": "📦 Bulk Import Snippets",
        "category": "Snippet Manager"
      },
      {
        "command": "snippetManager.exportSnippets",
        "title": "📤 Export Snippets",
        "category": "Snippet Manager"
      },
      {
        "command": "snippetManager.togglePreview",
        "title": "👁️ Toggle Snippet Preview",
        "category": "Snippet Manager"
      },
      {
        "command": "snippetManager.aiSuggest",
        "title": "🤖 AI Suggest Similar Snippets",
        "category": "Snippet Manager"
      }
    ],
    "keybindings": [
      {
        "command": "snippetManager.searchSnippets",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "editorTextFocus"
      },
      {
        "command": "snippetManager.saveSelection",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorHasSelection"
      },
      {
        "command": "snippetManager.insertSnippet",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "editorTextFocus"
      },
      {
        "command": "snippetManager.syncSnippets",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "snippetManager.saveSelection",
          "when": "editorHasSelection",
          "group": "snippetManager@1"
        },
        {
          "command": "snippetManager.insertSnippet",
          "when": "editorTextFocus",
          "group": "snippetManager@2"
        },
        {
          "command": "snippetManager.aiSuggest",
          "when": "editorHasSelection",
          "group": "snippetManager@3"
        }
      ],
      "view/title": [
        {
          "command": "snippetManager.syncSnippets",
          "when": "view == snippetManagerExplorer",
          "group": "navigation@1"
        },
        {
          "command": "snippetManager.createCollection",
          "when": "view == snippetManagerExplorer",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "snippetManager.insertSnippet",
          "when": "editorTextFocus"
        },
        {
          "command": "snippetManager.saveSelection",
          "when": "editorHasSelection"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "snippetManagerExplorer",
          "name": "🚀 Snippet Manager",
          "when": "snippetManager.showExplorer"
        }
      ]
    },
          "viewsContainers": {
      "activitybar": [
        {
          "id": "snippet-manager",
          "title": "Snippet Manager",
          "icon": "$(code)"
        }
      ]
    },
    "configuration": {
      "title": "Snippet Manager",
      "properties": {
        "snippetManager.apiUrl": {
          "type": "string",
          "default": "http://localhost:5000/api",
          "description": "API server URL for snippet synchronization"
        },
        "snippetManager.authToken": {
          "type": "string",
          "default": "",
          "description": "Authentication token for API access"
        },
        "snippetManager.autoSync": {
          "type": "boolean",
          "default": true,
          "description": "Automatically sync snippets when VS Code starts"
        },
        "snippetManager.syncInterval": {
          "type": "number",
          "default": 300,
          "description": "Auto-sync interval in seconds (0 to disable)"
        },
        "snippetManager.showPreview": {
          "type": "boolean",
          "default": true,
          "description": "Show snippet preview in search results"
        },
        "snippetManager.maxPreviewLines": {
          "type": "number",
          "default": 10,
          "description": "Maximum lines to show in snippet preview"
        },
        "snippetManager.enableAISuggestions": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI-powered snippet suggestions"
        },
        "snippetManager.defaultLanguage": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "javascript", "typescript", "python", "java", "csharp", "cpp", "php", "ruby", "go", "rust", "html", "css", "sql", "bash", "json", "yaml", "xml"],
          "description": "Default language for new snippets"
        },
        "snippetManager.saveLocation": {
          "type": "string",
          "default": "cloud",
          "enum": ["cloud", "local", "both"],
          "description": "Where to save snippets by default"
        },
        "snippetManager.insertBehavior": {
          "type": "string",
          "default": "replace",
          "enum": ["replace", "append", "prepend"],
          "description": "How to insert snippets at cursor position"
        },
        "snippetManager.searchFuzzy": {
          "type": "boolean",
          "default": true,
          "description": "Use fuzzy search for snippet discovery"
        },
        "snippetManager.groupByCollection": {
          "type": "boolean",
          "default": true,
          "description": "Group snippets by collection in explorer view"
        },
        "snippetManager.showLineNumbers": {
          "type": "boolean",
          "default": true,
          "description": "Show line numbers in snippet previews"
        },
        "snippetManager.highlightSyntax": {
          "type": "boolean",
          "default": true,
          "description": "Enable syntax highlighting in previews"
        },
        "snippetManager.autoDetectLanguage": {
          "type": "boolean",
          "default": true,
          "description": "Automatically detect programming language"
        },
        "snippetManager.enableCollaboration": {
          "type": "boolean",
          "default": false,
          "description": "Enable real-time collaboration features"
        },
        "snippetManager.notificationLevel": {
          "type": "string",
          "default": "info",
          "enum": ["none", "error", "warning", "info", "verbose"],
          "description": "Level of notifications to show"
        },
        "snippetManager.cacheSize": {
          "type": "number",
          "default": 1000,
          "description": "Maximum number of snippets to cache locally"
        },
        "snippetManager.exportFormat": {
          "type": "string",
          "default": "json",
          "enum": ["json", "markdown", "txt", "csv"],
          "description": "Default export format for snippets"
        }
      }
    },
    "snippets": [
      {
        "language": "javascript",
        "path": "./snippets/javascript.json"
      },
      {
        "language": "typescript",
        "path": "./snippets/typescript.json"
      },
      {
        "language": "python",
        "path": "./snippets/python.json"
      },
      {
        "language": "html",
        "path": "./snippets/html.json"
      },
      {
        "language": "css",
        "path": "./snippets/css.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "@types/mocha": "^9.1.1",
    "@types/glob": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "glob": "^8.0.3",
    "mocha": "^10.1.0",
    "typescript": "^4.9.4",
    "@vscode/test-electron": "^2.2.0",
    "@vscode/vsce": "^2.15.0"
  },
  "dependencies": {
    "axios": "^1.3.0",
    "fuse.js": "^6.6.2",
    "highlight.js": "^11.7.0",
    "ws": "^8.13.0",
    "uuid": "^9.0.0",
    "marked": "^4.2.12",
    "diff": "^5.1.0",
    "lodash": "^4.17.21"
  },
  "extensionDependencies": [],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/code-snippet-manager-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/code-snippet-manager-vscode/issues"
  },
  "homepage": "https://github.com/your-username/code-snippet-manager-vscode#readme",
