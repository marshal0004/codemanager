# ============================================================
# CODE-SNIPPET-MANAGER — .gitignore
# ============================================================
 
# ------------------------------------------------------------
# Python / Flask
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
 
# Virtual environments
.venv/
venv/
env/
ENV/
 
# Flask / instance config
flask-server/instance/
flask-server/app.log
 
# Database files
*.db
*.db-shm
*.db-wal
*.db-journal
*.db.backup_*
flask-server/data/dev_snippets.db
flask-server/data/dev_snippets.db.backup_*
 
# Logs
*.log
*.log.*
flask-server/data/logs/
 
# Uploads / user-generated content
flask-server/app/static/uploads/
flask-server/static/uploads/
 
# Environment / secrets
.env
.env.*
!.env.example
flask-server/cookies.txt
flask-server/session_cookie.txt
 
# Alembic (keep config, ignore auto-gen cache)
flask-server/migrations/versions/__pycache__/
 
# Leftover junk files (HTTP verb/header files accidentally created)
flask-server/Accept:
flask-server/Content-Length:
flask-server/Content-Type:
flask-server/Cookie:
flask-server/DELETE
flask-server/Host:
flask-server/POST
flask-server/User-Agent:
flask-server/X-Requested-With:
flask-server/lear
flask-server/os
flask-server/sys
flask-server/traceback
 
# ------------------------------------------------------------
# Node / Chrome Extension / VS Code Extension
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.npm/
 
# Chrome extension build artifacts
chrome-extension/.reload-signal
 
# ------------------------------------------------------------
# Docker
# ------------------------------------------------------------
.dockerignore
 
# ------------------------------------------------------------
# IDEs & Editors
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
 
# ------------------------------------------------------------
# Testing & Coverage
# ------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.tox/
nosetests.xml