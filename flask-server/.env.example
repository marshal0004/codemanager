# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-super-secret-key-here-change-in-production

# Database Configuration
DATABASE_URL=sqlite:///data/dev_snippets.db
# For PostgreSQL production: postgresql://username:password@localhost:5432/snippet_manager

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here

# Redis Configuration (optional, for caching and rate limiting)
REDIS_URL=redis://localhost:6379/0

# Email Configuration (for future features)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# External API Keys (for future integrations)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Monitoring (optional)
SENTRY_DSN=your-sentry-dsn-here

# Application Settings
MAX_SNIPPETS_FREE=100
MAX_COLLECTIONS_FREE=10
SNIPPETS_PER_PAGE=20

# Chrome Extension Settings
EXTENSION_ID=your-chrome-extension-id

# Server Configuration
HOST=127.0.0.1
PORT=5000

# Production Settings (use only in production)
# SESSION_COOKIE_SECURE=1
# SESSION_COOKIE_HTTPONLY=1
# PREFERRED_URL_SCHEME=https

# Development Settings (use only in development)
TEMPLATES_AUTO_RELOAD=1
EXPLAIN_TEMPLATE_LOADING=0

# Logging Level
LOG_LEVEL=DEBUG

# File Upload Settings
MAX_CONTENT_LENGTH=16777216  # 16MB in bytes

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Search Configuration
SEARCH_RESULTS_LIMIT=50
ENABLE_FULL_TEXT_SEARCH=1

# Feature Flags
ENABLE_USER_REGISTRATION=1
ENABLE_PUBLIC_SNIPPETS=1
ENABLE_SNIPPET_SHARING=1
ENABLE_COLLECTIONS=1

# Third-party Integrations (for future features)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Analytics (optional)
GOOGLE_ANALYTICS_ID=UA-your-analytics-id


# Search Engine Settings
SEARCH_MAX_RESULTS=100
SEARCH_HIGHLIGHT_MATCHES=true
SEARCH_MIN_QUERY_LENGTH=2
SEARCH_FUZZY_THRESHOLD=0.6

# Syntax Highlighting Settings  
HIGHLIGHT_THEME=github
HIGHLIGHT_LINE_NUMBERS=true
HIGHLIGHT_TAB_SIZE=4
HIGHLIGHT_WRAP_LONG_LINES=false

# Language Detection Settings
LANGUAGE_DETECTION_THRESHOLD=0.8
AUTO_TAGGING_ENABLED=true
MAX_AUTO_TAGS=5

# Export Service Settings
EXPORT_FORMATS=json,markdown,zip,csv
MAX_EXPORT_SIZE=50
MAX_EXPORT_FILE_SIZE=10485760
EXPORT_TEMP_DIR=temp/exports
EXPORT_CLEANUP_HOURS=24

# Analytics Settings
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90

# Performance Settings
SNIPPET_CACHE_TIMEOUT=300
SEARCH_CACHE_TIMEOUT=600

# File Upload Settings
MAX_CONTENT_LENGTH=5242880
ALLOWED_EXTENSIONS=json,md,txt,zip

# Rate Limiting Settings
RATELIMIT_STORAGE_URL=memory://
RATELIMIT_DEFAULT=100 per hour
RATELIMIT_SEARCH=50 per minute
RATELIMIT_EXPORT=10 per hour
